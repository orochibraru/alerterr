{
	"$schema": "./schema/config.schema.json",
	"intervalSeconds": 60,
	"checks": {
		"cpu": {
			"enabled": true,
			"usageThresholdPercent": 90,
			"tempThresholdCelsius": 85
		},
		"load": {
			"enabled": true,
			"threshold": 8.0
		},
		"memory": {
			"enabled": true,
			"usageThresholdPercent": 90
		},
		"disk": {
			"enabled": true,
			"usageThresholdPercent": 90,
			"volumes": ["/dev/sda"]
		}
	},
	"notifiers": [
		{
			"type": "discord",
			"webhookUrl": "https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN"
		}
	]
}
